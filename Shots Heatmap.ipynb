    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"khl_calendar.csv\")\n",
    "\n",
    "df = df.dropna(subset=['link'])\n",
    "\n",
    "df['match_id'] = df['link'].str.extract(r'/game/\\d+/(\\d+)/')\n",
    "\n",
    "print(df.head())"
   ]
